# Example environment variables for Docker deployment
# Copy this file to `.env` and fill values before running `docker compose up`.

# --- Application -----------------------------------------------------------
BASE_URL=http://localhost
LANGUAGE=english
DEBUG_MODE=false

# --- Database --------------------------------------------------------------
DB_HOST=mysql
DB_NAME=easyappointments
DB_USERNAME=user
DB_PASSWORD=password

# --- Google Calendar (optional) -------------------------------------------
GOOGLE_SYNC_FEATURE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Mail / SMTP ----------------------------------------------------------
# Set MAIL_PROTOCOL to "smtp" to use SMTP, or "mail" to use PHP mail()
MAIL_PROTOCOL=smtp
MAIL_MAILTYPE=html
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_USER=user@example.com
MAIL_SMTP_PASS=supersecret
MAIL_SMTP_PORT=587
MAIL_SMTP_CRYPTO=tls
MAIL_SMTP_AUTH=true
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Easy Appointments"
MAIL_REPLY_TO=

# --- Additional notes -----------------------------------------------------
# - Booleans: use true/false (not quoted). Docker-compose will pass them as strings;
#   the PHP code converts boolean-like strings to booleans where needed.
# - Keep actual `.env` file out of version control; add `.env` to .gitignore if not already.
# --- OpenLDAP -------------------------------------------------------------
# OpenLDAP defaults for local development
LDAP_ORGANISATION=example
LDAP_DOMAIN=example.org
LDAP_ADMIN_USERNAME=admin
LDAP_ADMIN_PASSWORD=admin
LDAP_CONFIG_PASSWORD=config_pass
LDAP_BASE_DN="dc=example,dc=org"
LDAP_READONLY_USER=true
LDAP_READONLY_USER_USERNAME=user
LDAP_READONLY_USER_PASSWORD=password

# --- PhpLDAPAdmin ---------------------------------------------------------
# PhpLDAPAdmin settings (optional)
PHPLDAPADMIN_LDAP_HOSTS=openldap
PHPLDAPADMIN_HTTPS=false

